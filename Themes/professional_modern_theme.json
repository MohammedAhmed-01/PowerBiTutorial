{
  "name": "Professional Vibrant Theme",
  "dataColors": [
    "#1F77B4",
    "#FF7F0E",
    "#2CA02C",
    "#D62728",
    "#9467BD",
    "#8C564B",
    "#E377C2",
    "#7F7F7F",
    "#BCBD22",
    "#17BECF",
    "#3498DB",
    "#E74C3C",
    "#2ECC71",
    "#F39C12",
    "#9B59B6",
    "#1ABC9C"
  ],
  "background": "#FFFFFF",
  "foreground": "#1A1A1A",
  "tableAccent": "#1F77B4",
  "good": "#2ECC71",
  "neutral": "#F39C12",
  "bad": "#E74C3C",
  "maximum": "#D62728",
  "center": "#F39C12",
  "minimum": "#3498DB",
  "null": "#7F7F7F",
  "textClasses": {
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 16,
      "color": "#1A1A1A"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 12,
      "color": "#1A1A1A"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 10,
      "color": "#1A1A1A"
    },
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 42,
      "color": "#1F77B4"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0,
            "show": true
          }
        ],
        "border": [
          {
            "color": {
              "solid": {
                "color": "#1F77B4"
              }
            },
            "show": true,
            "radius": 8
          }
        ],
        "visualHeader": [
          {
            "foreground": {
              "solid": {
                "color": "#1A1A1A"
              }
            },
            "background": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "show": true,
            "transparency": 0
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0,
            "show": true
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#1A1A1A"
              }
            },
            "fontSize": 12
          }
        ],
        "calloutValue": [
          {
            "color": {
              "solid": {
                "color": "#1F77B4"
              }
            },
            "fontSize": 36,
            "fontFace": "Segoe UI Semibold"
          }
        ]
      }
    }
  }
}